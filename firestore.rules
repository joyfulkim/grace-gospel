rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function validPrayer(data) {
      return data.keys().hasOnly(['nickname', 'content', 'category', 'createdAt']) &&
        data.nickname is string &&
        data.nickname.size() > 0 &&
        data.nickname.size() <= 18 &&
        data.content is string &&
        data.content.size() > 0 &&
        data.content.size() <= 280 &&
        data.category is string &&
        data.category in ['회복', '가정', '신앙', '감사', '치유', '일상'] &&
        data.createdAt is int &&
        data.createdAt > 0;
    }

    function validVisitor(data, dayId) {
      return data.keys().hasOnly(['dateKey', 'total', 'updatedAt']) &&
        data.dateKey is string &&
        data.dateKey == dayId &&
        data.dateKey.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
        data.total is int &&
        data.total > 0 &&
        data.updatedAt is int &&
        data.updatedAt > 0;
    }

    match /prayerWall/{postId} {
      allow read: if true;
      allow create: if validPrayer(request.resource.data);
      allow update, delete: if false;
    }

    match /dailyVisitors/{dayId} {
      allow read: if true;
      allow create: if validVisitor(request.resource.data, dayId) &&
        request.resource.data.total == 1;
      allow update: if validVisitor(request.resource.data, dayId) &&
        resource.data.dateKey is string &&
        resource.data.dateKey == dayId &&
        resource.data.total is int &&
        resource.data.updatedAt is int &&
        request.resource.data.total == resource.data.total + 1 &&
        request.resource.data.updatedAt >= resource.data.updatedAt;
      allow delete: if false;
    }
  }
}
